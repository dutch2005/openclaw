{
  "$schema": "../../src/config/config.schema.json",
  "agents": {
    "defaults": {
      "memorySearch": {
        "enabled": true,
        "provider": "auto",
        "store": {
          "driver": "postgresql",
          "postgresql": {
            "connectionString": "postgresql://openclaw:password@localhost:5432/openclaw",
            "schema": "agent_{agentId}",
            "pool": {
              "max": 10,
              "idleTimeoutMillis": 30000,
              "connectionTimeoutMillis": 5000
            },
            "vector": {
              "extension": "pgvector",
              "dimensions": 1536
            }
          }
        },
        "query": {
          "maxResults": 6,
          "minScore": 0.3,
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3
          }
        }
      }
    },
    "list": [
      {
        "id": "codex",
        "name": "Codex - Code Expert"
      },
      {
        "id": "sentinel",
        "name": "Sentinel - Security Expert"
      },
      {
        "id": "pixel",
        "name": "Pixel - Design Expert"
      },
      {
        "id": "architect",
        "name": "Architect - System Design Expert"
      },
      {
        "id": "main",
        "name": "Main - General Purpose Agent"
      }
    ]
  }
}
